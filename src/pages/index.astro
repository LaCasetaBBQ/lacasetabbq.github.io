<script is:inline>
/* ════════════════════════════════════════════════════════
   EDITABLE CONFIG — change things here, nowhere else needed
   ════════════════════════════════════════════════════════ */

// Regular weekly hours. 0 = Sunday, 1 = Monday, ... 6 = Saturday
const REGULAR_HOURS = {
  weekday: { open: '8:00', close: '23:00' },   // Mon–Fri
  weekend: { open: '8:00', close: '00:00' }    // Sat–Sun
};
function isWeekendDay(jsDay){ return jsDay === 0 || jsDay === 6; }

// Special days override the regular schedule AND can carry a news message.
// Add one entry per special date. Date format: 'YYYY-MM-DD'.
// Leave "hours" as null for a day that's simply closed.
const SPECIAL_DAYS = {
  // Example — delete or edit freely:
  // '2026-06-23': {
  //   hours: null,
  //   news: { es:'Cerrado por Sant Joan.', ca:'Tancat per Sant Joan.', en:'Closed for Sant Joan.' }
  // },
  // '2026-12-25': {
  //   hours: { open:'13:00', close:'17:00' },
  //   news: { es:'Horario especial de Navidad.', ca:'Horari especial de Nadal.', en:'Special Christmas hours.' }
  // },
};

// Default news text shown when there is no special day today.
// Edit the three lines below any time — they're just plain text.
const DEFAULT_NEWS = {
  es: 'Nada nuevo por ahora...',
  ca: 'Res de nou per ara...',
  en: 'Nothing new for now...'
};

/* ════════════════════════════════════════════════════════
   TRANSLATIONS — structural site text only (not dish data)
   ════════════════════════════════════════════════════════ */
const I18N = {
  es: {
    nav_inicio:'Inicio', nav_carta:'Carta', nav_galeria:'Galería', nav_contacto:'Contacto',
    hero_eyebrow:'Bar & Restaurant · Torredembarra',
    hero_desc:'Alquila nuestra parrilla por 18€ la hora, con capacidad de hasta 6 personas. Adecuado para compleaños, celebracios, y más.',
    hero_cta:'Ver la carta',
    carta_eyebrow:'La carta', carta_h2_pre:'Lo que servimos ', carta_h2_em:'hoy',
    tab_pinchos:'Pinchos a la Parrilla', tab_tapas:'Tapas', tab_asiaticos:'Asiáticos',
    galeria_eyebrow:'Galería', galeria_h2_pre:'La Caseta en ', galeria_h2_em:'imágenes',
    contacto_eyebrow:'Encuéntranos', contacto_h2_pre:'Ven a ', contacto_h2_em:'vernos',
    lbl_direccion:'Dirección', lbl_horario:'Horario', lbl_telefono:'Teléfono', lbl_news:'Novedades',
    status_open:'Abierto', status_closed:'Cerrado',
    maps_link:'Abrir en Google Maps →',
    footer_copy:'© 2026 BBQ La Caseta · Torredembarra'
  },
  ca: {
    nav_inicio:'Inici', nav_carta:'Carta', nav_galeria:'Galeria', nav_contacto:'Contacte',
    hero_eyebrow:'Bar & Restaurant · Torredembarra',
    hero_desc:'Llogueu la nostra graella per 18€ l\'hora, amb capacitat de fins a 6 persones. Adequat per a companys, celebracions, i més.',
    hero_cta:'Veure la carta',
    carta_eyebrow:'La carta', carta_h2_pre:'El que servim ', carta_h2_em:'avui',
    tab_pinchos:'Pinxos a la Graella', tab_tapas:'Tapes', tab_asiaticos:'Asiàtics',
    galeria_eyebrow:'Galeria', galeria_h2_pre:'La Caseta en ', galeria_h2_em:'imatges',
    contacto_eyebrow:'Troba\u2019ns', contacto_h2_pre:'Vine a ', contacto_h2_em:'veure\u2019ns',
    lbl_direccion:'Adreça', lbl_horario:'Horari', lbl_telefono:'Telèfon', lbl_news:'Novetats',
    status_open:'Obert', status_closed:'Tancat',
    maps_link:'Obrir a Google Maps →',
    footer_copy:'© 2026 BBQ La Caseta · Torredembarra'
  },
  en: {
    nav_inicio:'Home', nav_carta:'Menu', nav_galeria:'Gallery', nav_contacto:'Contact',
    hero_eyebrow:'Bar & Restaurant · Torredembarra',
    hero_desc:'Rent our grill for €18 per hour, with capacity for up to 6 people. Suitable for birthdays, celebrations, and more.',
    hero_cta:'View the menu',
    carta_eyebrow:'The menu', carta_h2_pre:'What we\u2019re serving ', carta_h2_em:'today',
    tab_pinchos:'Grilled Skewers', tab_tapas:'Tapas', tab_asiaticos:'Asian',
    galeria_eyebrow:'Gallery', galeria_h2_pre:'La Caseta in ', galeria_h2_em:'pictures',
    contacto_eyebrow:'Find us', contacto_h2_pre:'Come ', contacto_h2_em:'visit',
    lbl_direccion:'Address', lbl_horario:'Hours', lbl_telefono:'Phone', lbl_news:'News',
    status_open:'Open', status_closed:'Closed',
    maps_link:'Open in Google Maps →',
    footer_copy:'© 2026 BBQ La Caseta · Torredembarra'
  }
};

function detectLang(){
  const supported = ['es','ca','en'];
  const langs = navigator.languages && navigator.languages.length ? navigator.languages : [navigator.language || 'es'];
  for (const l of langs){
    const code = l.toLowerCase().slice(0,2);
    if (supported.includes(code)) return code;
  }
  return 'es'; // default, per requirement
}

function applyTranslations(lang){
  const dict = I18N[lang] || I18N.es;
  document.querySelectorAll('[data-i18n]').forEach(el=>{
    const key = el.getAttribute('data-i18n');
    if (dict[key] !== undefined) el.textContent = dict[key];
  });
  document.documentElement.lang = lang;
}

function pad(n){ return n.toString().padStart(2,'0'); }
function todayKey(d){ return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`; }

function getTodaysScheduleAndNews(lang){
  const now = new Date();
  const key = todayKey(now);
  const special = SPECIAL_DAYS[key];

  let hours;
  if (special && special.hours !== undefined){
    hours = special.hours; // may be null = closed
  } else {
    hours = isWeekendDay(now.getDay()) ? REGULAR_HOURS.weekend : REGULAR_HOURS.weekday;
  }

  let news;
  if (special && special.news){
    news = special.news[lang] || special.news.es;
  } else {
    news = DEFAULT_NEWS[lang] || DEFAULT_NEWS.es;
  }

  // Open/closed check only valid for same-day open/close (handles 00:00 as midnight)
  let isOpenNow = false;
  if (hours){
    const [oh,om] = hours.open.split(':').map(Number);
    let [ch,cm] = hours.close.split(':').map(Number);
    if (ch === 0 && cm === 0){ ch = 24; } // treat 00:00 close as midnight end-of-day
    const nowMinutes = now.getHours()*60 + now.getMinutes();
    const openMinutes = oh*60+om;
    const closeMinutes = ch*60+cm;
    isOpenNow = nowMinutes >= openMinutes && nowMinutes < closeMinutes;
  }

  return { hours, news, isOpenNow };
}

function renderHorarioAndNews(lang){
  const dict = I18N[lang] || I18N.es;
  const { hours, news, isOpenNow } = getTodaysScheduleAndNews(lang);

  const hoursText = hours ? `${hours.open} – ${hours.close}` : dict.status_closed;
  const statusText = hours ? (isOpenNow ? dict.status_open : dict.status_closed) : dict.status_closed;
  const dotColor = isOpenNow ? '#3FA34D' : '#A33F3F';

  // Top strip (single combined schedule now, no separate weekday/weekend columns)
  const stripEl = document.getElementById('horario-strip-value');
  if (stripEl) stripEl.textContent = hoursText;

  // "Find us" Horario row — status dot + text
  const dot = document.getElementById('horario-dot');
  const statusEl = document.getElementById('horario-status-text');
  const hoursEl = document.getElementById('horario-hours-text');
  if (dot) dot.style.background = dotColor;
  if (statusEl) statusEl.textContent = statusText;
  if (hoursEl) hoursEl.textContent = hoursText;

  // News box
  const newsEl = document.getElementById('news-text');
  if (newsEl) newsEl.textContent = news;
}

function initSite(){
  const lang = detectLang();
  applyTranslations(lang);
  renderHorarioAndNews(lang);
}
document.addEventListener('DOMContentLoaded', initSite);

function swap(id,btn){
  document.querySelectorAll('.menu-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  btn.classList.add('active');
}
</script>
</body>
