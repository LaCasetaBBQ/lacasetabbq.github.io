---
import { Image } from "astro:assets";
import heroImg from "../assets/terraza.jpg";
---

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BBQ La Caseta — Variante A (Cream)</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;0,900;1,600&family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --cream:    #F5EDD8;
  --cream2:   #EDE0C4;
  --burgundy: #6B1E1E;
  --burg-dk:  #4A1010;
  --gold:     #C8960A;
  --gold-lt:  #E0AA12;
  --brown:    #2C1810;
  --muted:    #7A5A40;
}

html{scroll-behavior:smooth}
body{background:var(--cream);color:var(--brown);font-family:'Lora',serif;font-weight:400;line-height:1.7;overflow-x:hidden}

/* dotted-line signature motif, reused everywhere */
.dotted-rule{
  flex:1;border-bottom:2px dotted var(--gold);
  margin:0 0.75rem;transform:translateY(-4px);
  min-width:24px;
}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.1rem 3.5rem;
  background:rgba(245,237,216,0.92);backdrop-filter:blur(8px);
  border-bottom:2px solid var(--gold);
}
.nav-logo{display:flex;align-items:center;gap:0.6rem;text-decoration:none}
.logo-b{
  font-family:'Playfair Display',serif;font-size:1.9rem;font-weight:900;
  color:var(--burgundy);line-height:1;
}
.logo-stack{line-height:1.1}
.logo-name{font-family:'Playfair Display',serif;font-size:0.95rem;font-weight:700;color:var(--burgundy);letter-spacing:0.05em}
.logo-sub{font-size:0.58rem;color:var(--gold);letter-spacing:0.18em;text-transform:uppercase}
.nav-links{display:flex;gap:2.25rem;list-style:none}
.nav-links a{
  color:var(--brown);text-decoration:none;font-family:'Inter',sans-serif;
  font-size:0.74rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;
  transition:color 0.2s;
}
.nav-links a:hover{color:var(--burgundy)}

/* ── HERO ── */
#inicio{
  min-height:92vh;display:flex;align-items:center;
  padding:7rem 3.5rem 3rem;position:relative;overflow:hidden;
}
.hero-photo-layer{position:absolute;inset:0;z-index:0}
.hero-photo-layer .fi-hero,.hero-photo-layer img{
  position:absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: translateX(20%);
}
/* the melt: solid cream over the text side, fading to transparent toward the right */
.hero-fade{
  position:absolute;inset:0;z-index:1;
  background:linear-gradient(to right,
    var(--cream) 0%,
    var(--cream) 38%,
    rgba(245,237,216,0.75) 52%,
    rgba(245,237,216,0) 78%
  );
}
.hero-inner{max-width:680px;position:relative;z-index:2}
.fi-hero{background:radial-gradient(ellipse at 65% 40%,#C8762A 0%,#8B4A18 35%,#4A2810 65%,#1A0E08 100%)}
.hero-inner{max-width:680px;position:relative;z-index:2}
.hero-eyebrow{
  display:flex;align-items:center;gap:0.7rem;
  font-family:'Inter',sans-serif;font-size:0.72rem;font-weight:600;
  letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1.4rem;
}
.hero-eyebrow::before{content:'';width:28px;height:2px;background:var(--gold)}

h1{
  font-family:'Playfair Display',serif;font-weight:900;
  font-size:clamp(3rem,7vw,5.6rem);line-height:1.0;color:var(--burgundy);
  margin-bottom:1.4rem;
}
h1 em{font-style:italic;color:var(--gold);font-weight:700}

.hero-desc{
  font-size:1.05rem;color:var(--muted);max-width:420px;margin-bottom:2.2rem;
}

.btn-primary{
  display:inline-block;font-family:'Inter',sans-serif;
  padding:0.9rem 2.1rem;background:var(--burgundy);color:var(--cream);
  text-decoration:none;font-size:0.76rem;font-weight:600;letter-spacing:0.12em;
  text-transform:uppercase;border:2px solid var(--burgundy);transition:all 0.2s;
}
.btn-primary:hover{background:transparent;color:var(--burgundy)}

/* ── SECTION SHARED ── */
section{padding:5.5rem 3.5rem}
.section-head{text-align:center;margin-bottom:3rem}
.eyebrow-center{
  display:inline-flex;align-items:center;gap:0.7rem;
  font-family:'Inter',sans-serif;font-size:0.72rem;font-weight:600;
  letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:0.9rem;
}
.eyebrow-center::before,.eyebrow-center::after{content:'';width:24px;height:2px;background:var(--gold)}

h2{
  font-family:'Playfair Display',serif;font-weight:700;
  font-size:clamp(2rem,4vw,3rem);color:var(--burgundy);line-height:1.12;
}
h2 em{font-style:italic;color:var(--gold);font-weight:600}

/* ── BURGUNDY BAND (alternation for contrast) ── */
#contacto.band-burgundy{background:var(--burgundy);color:var(--cream)}
#contacto.band-burgundy h2{color:var(--cream)}
#contacto.band-burgundy .eyebrow-center{color:var(--gold-lt)}
#contacto.band-burgundy .eyebrow-center::before,#contacto.band-burgundy .eyebrow-center::after{background:var(--gold-lt)}
#contacto.band-burgundy .c-label{color:var(--gold-lt)}
#contacto.band-burgundy .c-value,
#contacto.band-burgundy .c-value *{color:var(--cream)!important}
#contacto.band-burgundy .c-value a{border-color:var(--gold-lt)!important}
#contacto.band-burgundy .c-icon{border-color:var(--gold-lt)}

/* ── HORARIO STRIP ── */
#horario{
  background:var(--burgundy);padding:2.6rem 3.5rem;
  display:flex;justify-content:center;gap:3.5rem;flex-wrap:wrap;
}
.h-item{text-align:center;color:var(--cream)}
.h-label{font-family:'Inter',sans-serif;font-size:0.66rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--gold-lt);margin-bottom:0.4rem}
.h-value{font-family:'Playfair Display',serif;font-size:1.1rem}

/* ── CARTA ── */
#carta{background:var(--cream)}
.tabs-row{display:flex;justify-content:center;gap:0;margin-bottom:3.5rem;border:2px solid var(--gold);width:fit-content;margin-left:auto;margin-right:auto}
.tab-btn{
  font-family:'Inter',sans-serif;padding:0.65rem 1.5rem;font-size:0.72rem;font-weight:600;
  letter-spacing:0.1em;text-transform:uppercase;background:transparent;border:none;
  border-right:1px solid var(--gold);color:var(--muted);cursor:pointer;transition:all 0.2s;
}
.tab-btn:last-child{border-right:none}
.tab-btn.active{background:var(--burgundy);color:var(--cream)}
.tab-btn:not(.active):hover{background:rgba(200,150,10,0.1);color:var(--burgundy)}

.menu-panel{display:none}
.menu-panel.active{display:block}

.pinchos-cols{display:grid;grid-template-columns:1fr 1fr;gap:0 3.5rem;max-width:920px;margin:0 auto}
.m-row{display:flex;align-items:baseline;padding:0.85rem 0}
.m-name{font-family:'Lora',serif;font-size:0.98rem;white-space:nowrap}
.m-price{font-family:'Playfair Display',serif;font-weight:700;color:var(--burgundy);white-space:nowrap}

.tapas-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2.2rem 3rem;max-width:920px;margin:0 auto}
.t-card{display:grid;grid-template-columns:80px 1fr;gap:1.1rem}
.t-img{aspect-ratio:1;border:2px solid var(--gold)}
.t-img div{width:100%;height:100%}
.t-name{font-family:'Playfair Display',serif;font-weight:700;color:var(--burgundy);margin-bottom:0.15rem}
.t-price{font-size:0.82rem;color:var(--gold);font-weight:600;margin-bottom:0.4rem}
.t-desc{font-size:0.82rem;color:var(--muted)}

.fi1{background:radial-gradient(ellipse at 40% 30%,#C8762A,#5C3010 60%,#1A0E08)}
.fi2{background:radial-gradient(ellipse at 40% 30%,#4A6A1E,#243A0E 60%,#0A1404)}
.fi3{background:radial-gradient(ellipse at 40% 30%,#8B4A18,#4A2810 60%,#1A0E08)}
.fi4{background:radial-gradient(ellipse at 40% 30%,#C4A848,#6A5818 60%,#241E08)}
.fi5{background:radial-gradient(ellipse at 40% 30%,#C4A040,#6A5418 60%,#241E08)}
.fi6{background:radial-gradient(ellipse at 40% 30%,#7A7A44,#3A3A1E 60%,#141408)}
.fi7{background:radial-gradient(ellipse at 40% 30%,#7A4E24,#3A2410 60%,#140C04)}
.fi8{background:radial-gradient(ellipse at 40% 30%,#B86A28,#5C3210 60%,#1C0E04)}
.fi9{background:radial-gradient(ellipse at 40% 30%,#C4762A,#5C3812 60%,#1C1004)}
.fi10{background:radial-gradient(ellipse at 40% 30%,#D4B038,#6A5414 60%,#221C04)}
.fi11{background:radial-gradient(ellipse at 40% 30%,#B89858,#5C4E24 60%,#1E1A0C)}
.fi12{background:radial-gradient(ellipse at 40% 30%,#C8AC74,#6A5A3A 60%,#241E14)}
.fi13{background:radial-gradient(ellipse at 40% 30%,#C4502A,#6A2814 60%,#220C04)}
.fi14{background:radial-gradient(ellipse at 40% 30%,#C4602E,#6A3016 60%,#221004)}
.fi15{background:radial-gradient(ellipse at 40% 30%,#A89868,#544E34 60%,#1C1A10)}
.fi16{background:radial-gradient(ellipse at 40% 30%,#A8384A,#5A1C26 60%,#1E0A0E)}
.fi17{background:radial-gradient(ellipse at 40% 30%,#5E8A2E,#304616 60%,#101C06)}
.fi18{background:radial-gradient(ellipse at 40% 30%,#D87858,#6E3C2C 60%,#240E08)}
.fi19{background:radial-gradient(ellipse at 40% 30%,#E08868,#724436 60%,#260E08)}
.fi20{background:radial-gradient(ellipse at 40% 30%,#C49858,#624C2A 60%,#201A0C)}
.fi21{background:radial-gradient(ellipse at 40% 30%,#D89868,#6C4C34 60%,#221A10)}
.fi22{background:radial-gradient(ellipse at 40% 30%,#A85E2C,#562E14 60%,#1C0E04)}
.fi23{background:radial-gradient(ellipse at 40% 30%,#A87038,#56381C 60%,#1C1006)}
.fi24{background:radial-gradient(ellipse at 40% 30%,#C8722E,#643A16 60%,#201204)}
.fi25{background:radial-gradient(ellipse at 40% 30%,#C8841E,#64420E 60%,#201602)}

/* ── GALERÍA ── */
#galeria{background:var(--cream2)}
.gallery-row{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:2rem}
.g-cell{aspect-ratio:0.9;border:2px solid transparent;overflow:hidden;cursor:pointer;transition:border-color 0.25s}
.g-cell:hover{border-color:var(--gold)}
.g-cell div{width:100%;height:100%;transition:transform 0.45s}
.g-cell:hover div{transform:scale(1.05)}
.g1{background:radial-gradient(ellipse at 50% 40%,#8B4A18,#3A1E08 60%,#100A04)}
.g2{background:radial-gradient(ellipse at 50% 40%,#4A5C20,#1E2A0C 60%,#080C04)}
.g3{background:radial-gradient(ellipse at 50% 40%,#C4822A,#5C3810 60%,#180C04)}
.g4{background:radial-gradient(ellipse at 50% 40%,#8B6020,#3A2A0C 60%,#100C04)}

/* ── CONTACTO ── */
#contacto{background:var(--cream)}
.contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:4rem;max-width:980px;margin:0 auto}
.c-row{display:flex;gap:1.1rem;align-items:flex-start;margin-bottom:1.6rem}
.c-icon{width:38px;height:38px;min-width:38px;border:2px solid var(--gold);display:flex;align-items:center;justify-content:center;font-size:1rem}
.c-label{font-family:'Inter',sans-serif;font-size:0.66rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--gold);margin-bottom:0.3rem}
.c-value{font-size:0.95rem;color:var(--brown)}
.horario-status-row{display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap}
.status-dot{
  width:9px;height:9px;border-radius:50%;background:#3FA34D;
  flex:none;box-shadow:0 0 0 3px rgba(63,163,77,0.18);
}
#contacto.band-burgundy .status-dot{box-shadow:0 0 0 3px rgba(255,255,255,0.12)}
.status-sep{opacity:0.5}
.c-value a{color:var(--brown);text-decoration:none;border-bottom:1px solid var(--gold)}
.map-box{
  border:2px solid var(--gold);aspect-ratio:4/3;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:0.8rem;background:var(--cream2);
}
.map-pin{font-size:2rem}
.map-link{color:var(--burgundy);text-decoration:none;font-family:'Inter',sans-serif;font-size:0.7rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;border-bottom:2px solid var(--gold)}

/* ── FOOTER (sketch accent lives here) ── */
footer{
  background:var(--burg-dk);color:var(--cream);padding:2.2rem 3.5rem 1.4rem;
  position:relative;overflow:hidden;
}
.footer-top{display:flex;justify-content:space-between;align-items:center;position:relative;z-index:2}
.footer-logo{font-family:'Playfair Display',serif;font-weight:700;font-size:1.15rem}
.footer-logo em{font-style:italic;color:var(--gold-lt)}
footer p{font-family:'Inter',sans-serif;font-size:0.7rem;opacity:0.6}
.footer-links{display:flex;gap:1.4rem;list-style:none}
.footer-links a{font-family:'Inter',sans-serif;font-size:0.68rem;color:var(--cream);text-decoration:none;letter-spacing:0.08em;text-transform:uppercase;opacity:0.75}
.footer-sketch{position:absolute;bottom:-10px;right:1rem;width:180px;opacity:0.15;z-index:1}

@media (max-width:900px){
  nav{padding:0.9rem 1.25rem}.nav-links{display:none}
  section{padding:3.5rem 1.25rem}
  #inicio{padding-top:6.5rem}
  .hero-fade{
    background:linear-gradient(to bottom,
      var(--cream) 0%,
      var(--cream) 42%,
      rgba(245,237,216,0.7) 58%,
      rgba(245,237,216,0) 82%
    );
  }
  .pinchos-cols,.tapas-grid{grid-template-columns:1fr}
  .contact-wrap{grid-template-columns:1fr;gap:2.5rem}
  .gallery-row{grid-template-columns:1fr 1fr}
  #horario{gap:1.5rem}
  .footer-top{flex-direction:column;gap:0.8rem;text-align:center}
}
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="#inicio">
    <div class="logo-b">B</div>
    <div class="logo-stack">
      <div class="logo-name">BQ La Caseta</div>
      <div class="logo-sub">Bar &amp; Restaurant</div>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="#inicio" data-i18n="nav_inicio">Inicio</a></li>
    <li><a href="#carta" data-i18n="nav_carta">Carta</a></li>
    <li><a href="#galeria" data-i18n="nav_galeria">Galería</a></li>
    <li><a href="#contacto" data-i18n="nav_contacto">Contacto</a></li>
  </ul>
</nav>

<section id="inicio">
  <div class="hero-photo-layer">
    <Image src={heroImg} alt="Terraza de La Caseta" />
  </div>
  <div class="hero-fade"></div>
  <div class="hero-inner">
    <div class="hero-eyebrow" data-i18n="hero_eyebrow">Bar &amp; Restaurant · Torredembarra</div>
    <h1>Ahumado,<br>Carbonizado,<br>y <em>Jugoso</em></h1>
    <p class="hero-desc" data-i18n="hero_desc">Parrilla de leña, producto fresco y el calor de siempre. Desde el corazón de la Costa Daurada.</p>
    <a class="btn-primary" href="#carta" data-i18n="hero_cta">Ver la carta</a>
  </div>
</section>

<div id="horario">
  <div class="h-item"><div class="h-label">Lunes a viernes</div><div class="h-value">8:00 – 23:00</div></div>
  <div class="h-item"><div class="h-label">Fines de semana</div><div class="h-value">8:00 – 00:00</div></div>
  <div class="h-item"><div class="h-label">Reservas</div><div class="h-value">+34 641 24 57 54</div></div>
</div>

<section id="carta">
  <div class="section-head">
    <div class="eyebrow-center" data-i18n="carta_eyebrow">La carta</div>
    <h2><span data-i18n="carta_h2_pre">Lo que servimos </span><em data-i18n="carta_h2_em">hoy</em></h2>
  </div>

  <div class="tabs-row">
    <button class="tab-btn active" onclick="swap('pinchos',this)" data-i18n="tab_pinchos">Pinchos a la Parrilla</button>
    <button class="tab-btn" onclick="swap('tapas',this)" data-i18n="tab_tapas">Tapas</button>
    <button class="tab-btn" onclick="swap('asiaticos',this)" data-i18n="tab_asiaticos">Asiáticos</button>
  </div>

  <div id="panel-pinchos" class="menu-panel active">
    <div class="pinchos-cols">
      <div>
        <div class="m-row"><span class="m-name">Calçots (temporada)</span><span class="dotted-rule"></span><span class="m-price">9,95 €</span></div>
        <div class="m-row"><span class="m-name">Mazorca de maíz</span><span class="dotted-rule"></span><span class="m-price">3,00 €</span></div>
        <div class="m-row"><span class="m-name">Pincho de pimientos</span><span class="dotted-rule"></span><span class="m-price">1,50 €</span></div>
        <div class="m-row"><span class="m-name">Pincho de espárragos</span><span class="dotted-rule"></span><span class="m-price">1,50 €</span></div>
        <div class="m-row"><span class="m-name">Pincho de brócoli</span><span class="dotted-rule"></span><span class="m-price">1,50 €</span></div>
        <div class="m-row"><span class="m-name">Pincho de champiñones</span><span class="dotted-rule"></span><span class="m-price">1,50 €</span></div>
      </div>
      <div>
        <div class="m-row"><span class="m-name">Pincho de alitas</span><span class="dotted-rule"></span><span class="m-price">2,50 €</span></div>
        <div class="m-row"><span class="m-name">Pincho de panceta de cerdo</span><span class="dotted-rule"></span><span class="m-price">2,00 €</span></div>
        <div class="m-row"><span class="m-name">Pincho de ternera</span><span class="dotted-rule"></span><span class="m-price">3,00 €</span></div>
        <div class="m-row"><span class="m-name">Pincho de salchicha de cerdo</span><span class="dotted-rule"></span><span class="m-price">2,00 €</span></div>
        <div class="m-row"><span class="m-name">Pincho de salchicha de pollo</span><span class="dotted-rule"></span><span class="m-price">2,00 €</span></div>
        <div class="m-row"><span class="m-name">Pincho de gambas</span><span class="dotted-rule"></span><span class="m-price">4,00 €</span></div>
      </div>
    </div>
  </div>

  <div id="panel-tapas" class="menu-panel">
    <div class="tapas-grid">
      <div class="t-card"><div class="t-img"><div class="fi1"></div></div><div><div class="t-name">Patatas Bravas</div><div class="t-price">3,60 €</div><div class="t-desc">Dados de patata dorados y crujientes con salsa brava casera.</div></div></div>
      <div class="t-card"><div class="t-img"><div class="fi2"></div></div><div><div class="t-name">Pimiento Padrón</div><div class="t-price">3,90 €</div><div class="t-desc">Pimientos verdes salteados con un toque de sal gorda.</div></div></div>
      <div class="t-card"><div class="t-img"><div class="fi3"></div></div><div><div class="t-name">Pincho Moruno</div><div class="t-price">4,80 €</div><div class="t-desc">Dados de carne adobada con especias tradicionales, a la parrilla.</div></div></div>
      <div class="t-card"><div class="t-img"><div class="fi4"></div></div><div><div class="t-name">Queso Manchego</div><div class="t-price">4,90 €</div><div class="t-desc">Cuñas de auténtico queso manchego curado.</div></div></div>
      <div class="t-card"><div class="t-img"><div class="fi5"></div></div><div><div class="t-name">Calamares a la Romana</div><div class="t-price">5,00 €</div><div class="t-desc">Anillas de calamar con rebozado ligero y crujiente.</div></div></div>
      <div class="t-card"><div class="t-img"><div class="fi6"></div></div><div><div class="t-name">Rollo de la Casa (2u)</div><div class="t-price">5,50 €</div><div class="t-desc">Rollitos crujientes rellenos de verduras, con salsa agridulce.</div></div></div>
      <div class="t-card"><div class="t-img"><div class="fi7"></div></div><div><div class="t-name">Morros</div><div class="t-price">5,50 €</div><div class="t-desc">Trozos de morro de cerdo fritos, dorado y crujiente.</div></div></div>
      <div class="t-card"><div class="t-img"><div class="fi8"></div></div><div><div class="t-name">Patas de Calamar</div><div class="t-price">5,80 €</div><div class="t-desc">Rejos de calamar fritos con un toque de limón.</div></div></div>
      <div class="t-card"><div class="t-img"><div class="fi9"></div></div><div><div class="t-name">Alitas Fritas</div><div class="t-price">5,80 €</div><div class="t-desc">Alitas de pollo doradas y extracrujientes, perfectas para compartir.</div></div></div>
      <div class="t-card"><div class="t-img"><div class="fi10"></div></div><div><div class="t-name">Pollo Limón</div><div class="t-price">6,50 €</div><div class="t-desc">Jugosos trozos de pollo rebozado bañados en una suave y dulce salsa de limón.</div></div></div>
