<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>BBQ La Caseta — Bar & Restaurant</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Lora:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:      #F5EDD8;
      --cream-dark: #EDE0C4;
      --cream-deep: #E3D0A8;
      --burgundy:   #6B1E1E;
      --burg-dark:  #4A1010;
      --gold:       #C8960A;
      --gold-lt:    #E0AA12;
      --brown:      #2C1810;
      --brown-mid:  #5C3820;
      --brown-lt:   #8B5C38;
      --text:       #2C1810;
      --muted:      #7A5A40;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--cream);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
    }

    /* ── SKETCHY BACKGROUND PATTERN ─── */
    .sketch-bg {
      background-image:
        url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%236B1E1E' stroke-width='0.4' opacity='0.07'%3E%3Ccircle cx='20' cy='20' r='8'/%3E%3Cpath d='M60 15 Q65 10 70 15 Q65 20 60 15Z'/%3E%3Cpath d='M10 55 Q15 48 20 55 Q15 62 10 55Z'/%3E%3Cpath d='M55 60 L65 60 L60 50Z'/%3E%3C/g%3E%3C/svg%3E");
    }

    /* ── NAV ────────────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 3rem;
      background: rgba(245,237,216,0.95);
      backdrop-filter: blur(8px);
      border-bottom: 2px solid var(--gold);
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
    }

    .logo-b {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 900;
      color: var(--burgundy);
      line-height: 1;
    }

    .logo-text { line-height: 1.15; }

    .logo-bbq {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--burgundy);
      letter-spacing: 0.15em;
    }

    .logo-name {
      font-family: 'Playfair Display', serif;
      font-size: 0.7rem;
      color: var(--gold);
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .logo-sub {
      font-size: 0.6rem;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--brown-mid);
      text-decoration: none;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      transition: color 0.2s;
      position: relative;
      padding-bottom: 2px;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background: var(--gold);
      transform: scaleX(0);
      transition: transform 0.2s;
    }

    .nav-links a:hover { color: var(--burgundy); }
    .nav-links a:hover::after { transform: scaleX(1); }

    /* ── HERO ────────────────────────── */
    #inicio {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding-top: 72px;
      overflow: hidden;
    }

    .hero-left {
      background: var(--burgundy);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 4rem 4rem 3rem;
      position: relative;
      overflow: hidden;
    }

    /* Decorative sketch overlay on burgundy */
    .hero-left::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg width='120' height='120' viewBox='0 0 120 120' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23ffffff' stroke-width='0.5' opacity='0.04'%3E%3Ccircle cx='30' cy='30' r='15'/%3E%3Cpath d='M80 20 Q90 10 100 20 Q90 30 80 20Z'/%3E%3Cpath d='M20 80 L30 60 L40 80Z'/%3E%3Ccircle cx='90' cy='90' r='10'/%3E%3C/g%3E%3C/svg%3E");
      pointer-events: none;
    }

    .hero-eyebrow {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 28px;
      height: 1px;
      background: var(--gold);
    }

    h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 5vw, 4.5rem);
      font-weight: 900;
      line-height: 1.05;
      color: var(--cream);
      margin-bottom: 1.25rem;
    }

    h1 span { color: var(--gold); font-style: italic; }

    .hero-desc {
      font-size: 0.95rem;
      color: rgba(245,237,216,0.7);
      line-height: 1.8;
      max-width: 360px;
      margin-bottom: 2rem;
    }

    .hero-cta {
      display: inline-block;
      padding: 0.85rem 2rem;
      background: var(--gold);
      color: var(--brown);
      text-decoration: none;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      border: 2px solid var(--gold);
      transition: all 0.2s;
      align-self: flex-start;
    }

    .hero-cta:hover {
      background: transparent;
      color: var(--gold);
    }

    .hero-hours {
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(200,150,10,0.3);
    }

    .hero-hours-title {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }

    .hero-hours p {
      font-size: 0.82rem;
      color: rgba(245,237,216,0.6);
      line-height: 1.9;
      font-family: 'Lora', serif;
    }

    /* Right side: BBQ grill photo area */
    .hero-right {
      position: relative;
      background: #1a0a04;
      overflow: hidden;
    }

    .hero-right-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.85;
    }

    /* Placeholder grill visual */
    .grill-placeholder {
      width: 100%;
      height: 100%;
      background:
        radial-gradient(ellipse at 50% 30%, #8B3A0A 0%, #4A1E08 40%, #1a0a04 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }

    .grill-grates {
      display: grid;
      grid-template-rows: repeat(10, 1fr);
      gap: 12px;
      width: 85%;
      height: 65%;
      opacity: 0.4;
    }

    .grate-line {
      height: 3px;
      background: linear-gradient(90deg, transparent, #C87A20, #C87A20, transparent);
      border-radius: 2px;
    }

    .grill-label {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-style: italic;
      color: rgba(200,150,10,0.6);
      letter-spacing: 0.1em;
    }

    .hero-badge {
      position: absolute;
      bottom: 2rem;
      right: 2rem;
      background: var(--burgundy);
      border: 2px solid var(--gold);
      width: 100px;
      height: 100px;
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .badge-top {
      font-size: 0.55rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .badge-num {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      font-weight: 900;
      color: var(--cream);
      line-height: 1;
    }

    .badge-bot {
      font-size: 0.5rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
    }

    /* ── SECTION SHARED ─────────────── */
    section { padding: 5rem 3rem; }

    .section-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .section-eyebrow {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.75rem;
      display: block;
    }

    h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 700;
      color: var(--burgundy);
      line-height: 1.15;
    }

    .gold-divider {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      justify-content: center;
      margin: 1rem 0;
    }

    .gold-divider::before,
    .gold-divider::after {
      content: '';
      flex: 1;
      max-width: 80px;
      height: 1px;
      background: var(--gold);
    }

    .gold-divider-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
    }

    /* ── NOSOTROS ───────────────────── */
    #nosotros {
      background: var(--cream);
    }

    .nosotros-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
      max-width: 1100px;
      margin: 0 auto;
    }

    .nosotros-image {
      position: relative;
      aspect-ratio: 4/5;
      background: linear-gradient(160deg, #8B3A0A 0%, #4A1E08 60%, #1a0a04 100%);
      border: 3px solid var(--gold);
    }

    .nosotros-image::before {
      content: '';
      position: absolute;
      inset: 10px;
      border: 1px solid rgba(200,150,10,0.4);
      pointer-events: none;
    }

    .image-corner {
      position: absolute;
      width: 20px;
      height: 20px;
      border-color: var(--gold);
      border-style: solid;
    }

    .image-corner.tl { top: -2px; left: -2px; border-width: 3px 0 0 3px; }
    .image-corner.tr { top: -2px; right: -2px; border-width: 3px 3px 0 0; }
    .image-corner.bl { bottom: -2px; left: -2px; border-width: 0 0 3px 3px; }
    .image-corner.br { bottom: -2px; right: -2px; border-width: 0 3px 3px 0; }

    .image-inner-text {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .image-icon {
      font-size: 3rem;
      opacity: 0.3;
    }

    .image-caption {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-style: italic;
      color: rgba(200,150,10,0.5);
    }

    .nosotros-text p {
      font-family: 'Lora', serif;
      font-size: 0.95rem;
      color: var(--brown-mid);
      line-height: 1.9;
      margin-bottom: 1.25rem;
    }

    .info-row {
      display: flex;
      gap: 1.5rem;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--cream-deep);
    }

    .info-item {
      text-align: center;
      flex: 1;
    }

    .info-num {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 700;
      color: var(--burgundy);
      line-height: 1;
    }

    .info-label {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 0.25rem;
    }

    /* ── CARTA / MENÚ ───────────────── */
    #carta {
      background: var(--cream-dark);
    }

    .menu-tabs-wrap {
      display: flex;
      justify-content: center;
      gap: 0;
      margin-bottom: 3rem;
      border: 2px solid var(--gold);
      align-self: center;
      width: fit-content;
      margin-left: auto;
      margin-right: auto;
    }

    .mtab {
      padding: 0.65rem 1.5rem;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border: none;
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
      border-right: 1px solid var(--gold);
    }

    .mtab:last-child { border-right: none; }
    .mtab.active { background: var(--burgundy); color: var(--cream); }
    .mtab:not(.active):hover { background: rgba(200,150,10,0.12); color: var(--burgundy); }

    /* BBQ Hours banner */
    .bbq-hours {
      background: var(--burgundy);
      color: var(--cream);
      text-align: center;
      padding: 1.25rem 2rem;
      margin-bottom: 3rem;
      border: 2px solid var(--gold);
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }

    .bbq-hours-title {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--gold);
      margin-bottom: 0.4rem;
    }

    .bbq-hours p {
      font-size: 0.82rem;
      color: rgba(245,237,216,0.75);
      line-height: 1.7;
      font-family: 'Lora', serif;
    }

    /* Pinchos grid */
    .pinchos-list {
      max-width: 700px;
      margin: 0 auto;
    }

    .menu-item-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.85rem 0;
      border-bottom: 1px dotted var(--gold);
      gap: 1rem;
    }

    .menu-item-row:last-child { border-bottom: none; }

    .menu-item-row .m-name {
      font-family: 'Lora', serif;
      font-size: 0.95rem;
      color: var(--brown);
      flex: 1;
    }

    .menu-item-row .m-dots {
      flex: 1;
      border-bottom: 1px dotted rgba(107,30,30,0.25);
      margin-bottom: 4px;
    }

    .menu-item-row .m-price {
      font-family: 'Playfair Display', serif;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--burgundy);
      white-space: nowrap;
    }

    /* Tapas grid */
    .tapas-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .tapa-card {
      display: grid;
      grid-template-columns: 1fr 110px;
      gap: 1rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--cream-deep);
    }

    .tapa-info {}

    .tapa-name {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--burgundy);
      margin-bottom: 0.2rem;
    }

    .tapa-price {
      font-family: 'Lora', serif;
      font-size: 0.85rem;
      color: var(--gold);
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .tapa-desc {
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.6;
      font-family: 'Lora', serif;
    }

    .tapa-img {
      aspect-ratio: 1;
      border: 2px solid var(--gold);
      overflow: hidden;
      position: relative;
    }

    .tapa-img-inner {
      width: 100%;
      height: 100%;
    }

    /* Food photo colors for tapas */
    .fi-bravas   { background: radial-gradient(ellipse at 50% 60%, #C87A20 0%, #7A3A10 50%, #3A1808 100%); }
    .fi-padron   { background: radial-gradient(ellipse at 50% 40%, #3A6A20 0%, #1A3A10 50%, #0A1808 100%); }
    .fi-moruno   { background: radial-gradient(ellipse at 50% 50%, #8B3A10 0%, #4A1E08 50%, #1A0A04 100%); }
    .fi-manchego { background: radial-gradient(ellipse at 50% 40%, #D4AA40 0%, #8A6A20 50%, #3A2A08 100%); }
    .fi-calamares{ background: radial-gradient(ellipse at 50% 50%, #D4A840 0%, #8A6020 50%, #3A2808 100%); }
    .fi-rollo    { background: radial-gradient(ellipse at 50% 60%, #8B8B50 0%, #4A4A28 50%, #1A1A10 100%); }
    .fi-morros   { background: radial-gradient(ellipse at 50% 50%, #8B5A30 0%, #4A2A18 50%, #1A0E08 100%); }
    .fi-patas    { background: radial-gradient(ellipse at 50% 50%, #C4702A 0%, #7A3A14 50%, #3A1808 100%); }

    /* Panel switching */
    .menu-panel { display: none; }
    .menu-panel.active { display: block; }

    /* ── GALERÍA ────────────────────── */
    #galeria {
      background: var(--cream);
      padding-bottom: 4rem;
    }

    .gallery-mosaic {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: 200px 200px;
      gap: 4px;
      max-width: 1100px;
      margin: 2.5rem auto 0;
    }

    .gm-cell {
      overflow: hidden;
      border: 2px solid transparent;
      cursor: pointer;
      transition: border-color 0.25s;
      position: relative;
    }

    .gm-cell:hover { border-color: var(--gold); }
    .gm-cell:nth-child(1) { grid-column: span 2; grid-row: span 2; }
    .gm-cell:nth-child(5) { grid-column: span 2; }

    .gm-inner {
      width: 100%;
      height: 100%;
      transition: transform 0.5s ease;
    }

    .gm-cell:hover .gm-inner { transform: scale(1.04); }

    .gm-overlay {
      position: absolute;
      inset: 0;
      background: rgba(107,30,30,0);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.3s;
    }

    .gm-cell:hover .gm-overlay { background: rgba(107,30,30,0.2); }

    .gc1 { background: radial-gradient(ellipse at 50% 50%, #8B3A10 0%, #4A1E08 50%, #1a0A04 100%); }
    .gc2 { background: radial-gradient(ellipse at 50% 50%, #4A6820 0%, #283A10 50%, #101808 100%); }
    .gc3 { background: radial-gradient(ellipse at 50% 50%, #C8720A 0%, #7A3A08 50%, #3A1A04 100%); }
    .gc4 { background: radial-gradient(ellipse at 50% 50%, #8B6020 0%, #4A3010 50%, #1A1008 100%); }
    .gc5 { background: radial-gradient(ellipse at 50% 50%, #A84020 0%, #6A2010 50%, #2A0E08 100%); }

    /* ── CONTACTO ───────────────────── */
    #contacto {
      background: var(--burgundy);
      color: var(--cream);
    }

    #contacto h2 { color: var(--cream); }
    #contacto .section-eyebrow { color: var(--gold-lt); }
    #contacto .gold-divider::before,
    #contacto .gold-divider::after { background: rgba(200,150,10,0.4); }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .contact-details { display: flex; flex-direction: column; gap: 1.5rem; }

    .c-row {
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
    }

    .c-icon {
      width: 42px;
      height: 42px;
      min-width: 42px;
      border: 1px solid rgba(200,150,10,0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      margin-top: 2px;
      background: rgba(200,150,10,0.08);
    }

    .c-label {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.3rem;
    }

    .c-value {
      font-family: 'Lora', serif;
      font-size: 0.95rem;
      color: rgba(245,237,216,0.85);
      line-height: 1.65;
    }

    .c-value a {
      color: rgba(245,237,216,0.85);
      text-decoration: none;
    }

    .map-box {
      border: 2px solid rgba(200,150,10,0.4);
      aspect-ratio: 4/3;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      background: rgba(0,0,0,0.2);
      position: relative;
      overflow: hidden;
    }

    .map-box::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 35px, rgba(200,150,10,0.06) 35px, rgba(200,150,10,0.06) 36px),
        repeating-linear-gradient(90deg, transparent, transparent 35px, rgba(200,150,10,0.06) 35px, rgba(200,150,10,0.06) 36px);
    }

    .map-pin { font-size: 2.5rem; position: relative; z-index: 1; }

    .map-address {
      font-family: 'Lora', serif;
      font-size: 0.85rem;
      color: rgba(245,237,216,0.6);
      text-align: center;
      position: relative;
      z-index: 1;
      line-height: 1.6;
    }

    .map-link {
      position: relative;
      z-index: 1;
